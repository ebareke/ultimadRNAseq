/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Signal-path test profile — exercises Phase 2 (POD5/FAST5 → Dorado → f5c).
    Use with -stub-run (no GPU / real signal data on CI).
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Signal test profile'
    config_profile_description = 'POD5 + FAST5 inputs through Dorado basecalling and f5c'

    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '2.h'

    input = "${projectDir}/assets/samplesheet_signal_test.csv"
    mode  = 'reference'

    // turn the opt-in signal stages on
    run_dorado    = true
    run_f5c       = true
    run_uncalled4 = true

    // exercise RNA modification detection (Phase 3)
    skip_modifications = false

    // exercise poly(A) tail analysis (Phase 4)
    skip_polya = false

    // reference fixtures (for alignment / f5c eventalign)
    fasta            = "${projectDir}/tests/data/reference/genome.fa"
    gtf              = "${projectDir}/tests/data/reference/genes.gtf"
    transcript_fasta = "${projectDir}/tests/data/reference/transcripts.fa"
}
