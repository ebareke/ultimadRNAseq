/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Tiny test profile — runnable on a laptop in minutes
    Real test data wired up in Phase 1.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset for CI smoke tests'

    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '2.h'

    input = "${projectDir}/assets/samplesheet_test.csv"
    mode  = 'reference'

    // tiny reference fixtures
    fasta            = "${projectDir}/tests/data/reference/genome.fa"
    gtf              = "${projectDir}/tests/data/reference/genes.gtf"
    transcript_fasta = "${projectDir}/tests/data/reference/transcripts.fa"

    // exercise the second quantifier (NanoCount) alongside Salmon
    run_nanocount    = true
}
