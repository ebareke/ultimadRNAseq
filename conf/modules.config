/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-process publishDir & ext.args overrides.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    // Default: publish each process under a dir named after the process.
    publishDir = [
        path:    { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode:    params.publish_dir_mode,
        saveAs:  { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ---- Signal & basecalling (spec §5.2) ---------------------------------
    withName: 'POD5_CONVERT' {
        publishDir = [
            path: { "${params.outdir}/signal/pod5/${meta.id}" },
            mode: params.publish_dir_mode,
            enabled: false   // intermediate; large. Enable to retain converted POD5.
        ]
    }
    withName: 'DORADO_BASECALLER' {
        ext.prefix = { "${meta.id}.calls" }
        publishDir = [
            path: { "${params.outdir}/signal/dorado/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'DORADO_SUMMARY' {
        publishDir = [
            path: { "${params.outdir}/signal/dorado/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'SAMTOOLS_FASTQ' {
        publishDir = [
            path: { "${params.outdir}/signal/fastq" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'F5C_EVENTALIGN_TXOME' {
        ext.args   = '--rna --signal-index --scale-events'
        ext.prefix = { "${meta.id}.transcriptome" }
        publishDir = [
            path: { "${params.outdir}/signal/f5c/${meta.id}/transcriptome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'F5C_EVENTALIGN_GENOME' {
        ext.args   = '--rna --signal-index --scale-events'
        ext.prefix = { "${meta.id}.genome" }
        publishDir = [
            path: { "${params.outdir}/signal/f5c/${meta.id}/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ---- RNA modifications (spec §5.5) ------------------------------------
    withName: 'M6ANET' {
        // emitted output dir is already named after the sample (${meta.id})
        publishDir = [
            path: { "${params.outdir}/modifications/m6anet" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'NANOCOMPORE_COLLAPSE' {
        publishDir = [ path: { "${params.outdir}/modifications/nanocompore/collapse" },
                       mode: params.publish_dir_mode, enabled: false ]   // intermediate
    }
    withName: 'NANOCOMPORE_SAMPCOMP' {
        publishDir = [
            path: { "${params.outdir}/modifications/nanocompore" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'ELIGOS_PAIRDIFF' {
        publishDir = [
            path: { "${params.outdir}/modifications/eligos" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'NANORMS' {
        publishDir = [
            path: { "${params.outdir}/modifications/nanorms" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ---- Poly(A) tail analysis (spec §5.6) --------------------------------
    withName: 'NANOPOLISH_POLYA' {
        publishDir = [
            path: { "${params.outdir}/polya/nanopolish" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'TAILFINDR' {
        publishDir = [
            path: { "${params.outdir}/polya/tailfindr" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ---- QC (spec §5.3) ----------------------------------------------------
    withName: 'NANOPLOT' {
        ext.args  = '--loglength --N50'
        publishDir = [
            path: { "${params.outdir}/qc/nanoplot/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'TOULLIGQC' {
        publishDir = [
            path: { "${params.outdir}/qc/toulligqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'PYCOQC' {
        publishDir = [
            path: { "${params.outdir}/qc/pycoqc/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ---- Alignment (spec §5.4) --------------------------------------------
    withName: 'MINIMAP2_GENOME' {
        // direct-RNA splice-aware genome alignment
        ext.args   = '-ax splice -uf -k14'
        ext.prefix = { "${meta.id}.genome" }
        publishDir = [
            path: { "${params.outdir}/alignment/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'MINIMAP2_TXOME' {
        // transcriptome alignment for quantification
        ext.args   = '-ax map-ont'
        ext.prefix = { "${meta.id}.transcriptome" }
        publishDir = [
            path: { "${params.outdir}/alignment/transcriptome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ---- Quantification (spec §5.4) ---------------------------------------
    withName: 'SALMON_QUANT' {
        ext.args   = '--ont'
        publishDir = [
            path: { "${params.outdir}/quantification/salmon" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ---- De novo transcript discovery (spec §5.7) -------------------------
    withName: 'RATTLE' {
        publishDir = [ path: { "${params.outdir}/denovo/rattle/${meta.id}" },
                       mode: params.publish_dir_mode,
                       saveAs: { f -> f.equals('versions.yml') ? null : f } ]
    }
    withName: 'STRINGTIE2' {
        publishDir = [ path: { "${params.outdir}/denovo/stringtie/${meta.id}" },
                       mode: params.publish_dir_mode,
                       saveAs: { f -> f.equals('versions.yml') ? null : f } ]
    }
    withName: 'GFFREAD' {
        publishDir = [ path: { "${params.outdir}/denovo/stringtie/${meta.id}" },
                       mode: params.publish_dir_mode,
                       saveAs: { f -> f.equals('versions.yml') ? null : f } ]
    }
    withName: 'GFFCOMPARE' {
        publishDir = [ path: { "${params.outdir}/denovo/gffcompare/${meta.id}" },
                       mode: params.publish_dir_mode,
                       saveAs: { f -> f.equals('versions.yml') ? null : f } ]
    }
    withName: 'SALMON_DENOVO' {
        publishDir = [ path: { "${params.outdir}/denovo/quantification" },
                       mode: params.publish_dir_mode,
                       saveAs: { f -> f.equals('versions.yml') ? null : f } ]
    }

    // ---- Reporting (spec §8) ----------------------------------------------
    withName: 'SUMMARY_REPORT' {
        publishDir = [
            path: { "${params.outdir}/report" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'MULTIQC' {
        ext.args   = "--title \"${params.multiqc_title ?: 'directRNA report'}\""
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
