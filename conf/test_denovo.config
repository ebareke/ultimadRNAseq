/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    De novo test profile — exercises Phase 5 (mode='denovo').
    RATTLE (reference-free) + StringTie2 (genome-guided) + characterisation +
    de novo quantification. Use with -stub-run.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'De novo test profile'
    config_profile_description = 'FASTQ → RATTLE + StringTie2 + gffcompare + de novo quant'

    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '2.h'

    input = "${projectDir}/assets/samplesheet_test.csv"
    mode  = 'denovo'

    skip_denovo = false

    // genome provided → enables the genome-guided StringTie2 arm + gffcompare
    fasta = "${projectDir}/tests/data/reference/genome.fa"
    gtf   = "${projectDir}/tests/data/reference/genes.gtf"
    // no transcript_fasta → Salmon (reference-mode) stays off; de novo quant runs
}
