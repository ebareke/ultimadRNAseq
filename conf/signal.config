/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Signal + GPU profile — full raw-signal run.

    POD5/FAST5 → Dorado basecalling (GPU) → f5c eventalign → RNA modifications
    + poly(A). Reference-guided (genome + transcriptome needed for eventalign /
    modification calling).

    Combine with an executor profile and edit the GPU resource line below:
        nextflow run . -profile signal,hpc --outdir results

    Provide your own raw-signal sample sheet (assets/samplesheet_signal.csv is a
    template). See docs/signal_gpu_run.md.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Signal + GPU'
    config_profile_description  = 'POD5/FAST5 → Dorado → f5c → modifications + poly(A)'

    mode  = 'reference'
    input = "${projectDir}/assets/samplesheet_signal.csv"

    // signal stages ON
    run_dorado         = true
    run_f5c            = true
    skip_modifications = false
    skip_polya         = false

    // basecalling model — match your chemistry (RNA004 shown; RNA002 for older data)
    dorado_model = 'rna004_130bps_sup@v5.1.0'

    // references (GENCODE v44 human; override for other organisms)
    fasta            = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/GRCh38.primary_assembly.genome.fa.gz'
    gtf              = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.primary_assembly.annotation.gtf.gz'
    transcript_fasta = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.transcripts.fa.gz'

    max_cpus   = 16
    max_memory = '120.GB'
    max_time   = '72.h'
}

process {
    // GPU request for Dorado (and any process_gpu task). EDIT to your scheduler:
    //   --gres=gpu:1   is SLURM syntax; set the GPU partition with `queue`.
    withLabel: process_gpu {
        clusterOptions = '--gres=gpu:1'
        queue          = 'gpu'      // <-- change to your cluster's GPU partition
    }
}

// expose the GPU inside the container (Dorado needs CUDA)
apptainer.runOptions   = '--nv'
singularity.runOptions = '--nv'
docker.runOptions      = '--gpus all -u $(id -u):$(id -g)'

