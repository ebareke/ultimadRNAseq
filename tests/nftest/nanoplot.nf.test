nextflow_process {

    name "NANOPLOT module (stub)"
    script "modules/local/nanoplot.nf"
    process "NANOPLOT"

    test("emits report, stats and versions") {
        options "-stub"
        when {
            process {
                """
                input[0] = [ [ id:'WT_rep1', single_end:true ],
                             file("\${projectDir}/tests/data/wt_rep1.fastq.gz") ]
                """
            }
        }
        then {
            assert process.success
            assert process.out.html.size() == 1
            assert process.out.txt.size()  == 1
            assert process.out.versions.size() == 1
            assert path(process.out.versions.get(0)).getText().contains("nanoplot")
        }
    }
}
