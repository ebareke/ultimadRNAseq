/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    directRNA — Oxford Nanopore Direct RNA-seq Analysis Platform
    Top-level Nextflow configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

manifest {
    name            = 'directRNA'
    author          = 'directRNA contributors'
    homePage        = 'https://github.com/ebareke/directRNA'
    description     = 'Reproducible analysis platform for Oxford Nanopore direct RNA sequencing'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04.0'
    version         = '0.0.1-dev'
}

// ----------------------------------------------------------------------------
// Workflow parameters (all overridable on CLI or via -params-file)
// ----------------------------------------------------------------------------
params {
    // Input / output
    input                       = null              // sample sheet CSV
    outdir                      = './results'
    publish_dir_mode            = 'copy'

    // Workflow mode
    mode                        = 'reference'       // 'reference' | 'denovo'

    // References (reference-guided mode)
    genome                      = null              // genome key (igenomes-style, future)
    fasta                       = null              // genome FASTA
    gtf                         = null              // gene annotation
    transcript_fasta            = null              // transcriptome FASTA

    // Signal / basecalling — disabled by default per spec §5.2
    run_dorado                  = false
    run_f5c                     = false
    run_uncalled4               = false
    dorado_model                = 'rna004_130bps_sup@v3.0.1'

    // Module toggles (default: enabled where sensible)
    skip_qc                     = false
    skip_alignment              = false
    skip_quantification         = false
    skip_modifications          = true              // off by default until Phase 3
    skip_polya                  = true              // off by default until Phase 4
    skip_denovo                 = true              // off by default until Phase 5
    skip_multiqc                = false
    skip_report                 = false

    // Resource caps (overridden in profiles)
    max_cpus                    = 16
    max_memory                  = '128.GB'
    max_time                    = '72.h'

    // Reporting
    multiqc_config              = null
    multiqc_title               = null

    // Misc
    help                        = false
    validate_params             = true
    monochrome_logs             = false
    tracedir                    = "${params.outdir}/pipeline_info"
}

// ----------------------------------------------------------------------------
// Process resource defaults & per-process tuning
// ----------------------------------------------------------------------------
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// ----------------------------------------------------------------------------
// Execution profiles
// ----------------------------------------------------------------------------
profiles {
    standard {
        // local executor, conda environments
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
        apptainer.enabled      = false
        conda.useMamba         = true
    }

    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        conda.enabled          = false
        singularity.enabled    = false
        apptainer.enabled      = false
    }

    apptainer {
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        docker.enabled         = false
        singularity.enabled    = false
        conda.enabled          = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        apptainer.enabled      = false
        conda.enabled          = false
    }

    slurm {
        process.executor       = 'slurm'
        process.queue          = 'normal'
        executor.queueSize     = 100
        executor.submitRateLimit = '10/1min'
    }

    hpc {
        // Convenience: SLURM + Apptainer, typical academic HPC stack
        process.executor       = 'slurm'
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        executor.queueSize     = 100
    }

    test        { includeConfig 'conf/test.config' }
    test_signal { includeConfig 'conf/test_signal.config' }
    test_denovo { includeConfig 'conf/test_denovo.config' }
    test_full   { includeConfig 'conf/test_full.config' }
    sgnex       { includeConfig 'conf/sgnex.config' }
    signal      { includeConfig 'conf/signal.config' }
}

// ----------------------------------------------------------------------------
// Capture workflow execution metadata (provenance — spec §11)
// timestamp inlined per-statement: the strict config parser forbids top-level
// `def` variables, so we compute it inside each GString.
// ----------------------------------------------------------------------------
timeline { enabled = true; file = "${params.tracedir}/execution_timeline_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html" }
report   { enabled = true; file = "${params.tracedir}/execution_report_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html" }
trace    { enabled = true; file = "${params.tracedir}/execution_trace_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.txt" }
dag      { enabled = true; file = "${params.tracedir}/pipeline_dag_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html" }
